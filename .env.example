# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3001
FRONTEND_URL=http://localhost:3000
LOG_LEVEL=info

# ─── Stellar / Soroban ────────────────────────────────────────────────────────
# Set MOCK_CONTRACT=true to run without a live Stellar node (development mode)
MOCK_CONTRACT=true

SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_NETWORK=testnet

# Your deployed micropay contract ID
MICROPAY_CONTRACT_ADDRESS=CAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAABSC4

# The DAO Treasury contract that is allowed to fund user accounts
TREASURY_CONTRACT_ADDRESS=CBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBB

# Backend admin wallet (signs charge() calls)
ADMIN_SECRET_KEY=SXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ─── Billing ─────────────────────────────────────────────────────────────────
# Cost per /premium-data request in stroops (1 XLM = 10,000,000 stroops)
# Default: 10000 stroops = 0.001 XLM
CHARGE_STROOPS=10000
